APP_NAME="Grow with DXN"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000
CLIENT_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=growwithdxn
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=10080

# OpenAI / AI Provider (for laravel/ai)
AI_PROVIDER=openai
OPENAI_API_KEY=

# MCP (for laravel/mcp)
MCP_SERVER_ENABLED=true

# Meta Pixel + Conversions API (server-side event tracking)
# Get token from: Events Manager → Dataset → Settings → Conversions API → Generate access token
# Set TEST_EVENT_CODE only while validating in Test Events tab; remove for production traffic.
META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=
META_TEST_EVENT_CODE=

# Klaviyo lead automation
# Private key must include profiles:write, lists:write, and subscriptions:write scopes.
KLAVIYO_PRIVATE_API_KEY=
KLAVIYO_COMPANY_ID=Rks7DY
KLAVIYO_BASE_URL=https://a.klaviyo.com/api
# Use the short Klaviyo list ID, for example XcSaDx, not the full list URL.
KLAVIYO_LIST_ID=
KLAVIYO_REVISION=2026-04-15
KLAVIYO_TIMEOUT=15
KLAVIYO_CONNECT_TIMEOUT=5
KLAVIYO_QUEUE=klaviyo
# Optional local PHP/cURL CA bundle path, useful on Windows PHP installs.
KLAVIYO_CA_BUNDLE=
